    "serve": "cd ../api && pnpm install && pnpm run build && cd - && vite preview",
    "test": "cd ../api && pnpm install && pnpm run build && cd - && vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "biome-ci": "biome ci",
    "steiger": "steiger ./src",
    "preinstall": "npx only-allow pnpm"
  },
